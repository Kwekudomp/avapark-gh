# Neon Postgres (pooled connection string from console.neon.tech)
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Session signing secret (openssl rand -hex 32)
SESSION_SECRET=generate-with--openssl-rand-hex-32

# Bootstrap admin — used ONLY by scripts/seed-neon.mjs to create the first
# admin user; staff accounts are managed in /admin/users afterwards.
ADMIN_EMAIL=info@hiddenparadisegh.com
ADMIN_PASSWORD=choose-a-strong-password

# Cloudflare R2 (media uploads)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET=hiddenparadise-media
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Site lock (optional override: maintenance | lockdown) + /sys control password
# MAINTENANCE_MODE=
MAINTENANCE_SECRET=choose-a-strong-password

# WhatsApp agent (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Anthropic (WhatsApp agent classifier/generator)
ANTHROPIC_API_KEY=

# Email notifications
RESEND_API_KEY=

# Paystack
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxx
PAYSTACK_SECRET_KEY=sk_live_xxxx
